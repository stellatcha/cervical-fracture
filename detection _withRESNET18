    "# Wrapper per adattare il modello alla Grad-CAM\n",
    "class GradCAMWrapper(nn.Module):\n",
    "    def __init__(self, full_model):\n",
    "        super().__init__()\n",
    "        self.encoder = full_model.encoder\n",
    "        self.fc = full_model.fc\n",
    "    def forward(self, x):\n",
    "        features = self.encoder(x).view(x.size(0), -1)\n",
    "        return self.fc(features)\n",
    "\n",
    "def visualize_results(model_path, patient_idx=10):\n",
    "    DEVICE = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
    "    df = pd.read_csv(TRAIN_CSV)\n",
    "    ds = RSNAKaggleDataset(df, TRAIN_IMAGES_DIR)\n",
    "    images_stack, _ = ds[patient_idx]\n",
    "    \n",
    "    model = MultiVertebraModel().to(DEVICE)\n",
    "    model.load_state_dict(torch.load(model_path))\n",
    "    model.eval()\n",
    "\n",
    "    wrapped_model = GradCAMWrapper(model).to(DEVICE)\n",
    "    target_layers = [wrapped_model.encoder[-1]]\n",
    "    cam = GradCAM(model=wrapped_model, target_layers=target_layers)\n",
    "    \n",
    "    v_idx = 3 # Vertebra C4\n",
    "    input_tensor = images_stack[v_idx].unsqueeze(0).to(DEVICE)\n",
    "    grayscale_cam = cam(input_tensor=input_tensor, targets=[BinaryClassifierOutputTarget(0)])[0, :]\n",
    "    \n",
    "    img_to_show = images_stack[v_idx].permute(1, 2, 0).cpu().numpy()\n",
    "    img_to_show = (img_to_show - img_to_show.min()) / (img_to_show.max() - img_to_show.min() + 1e-9)\n",
    "    visualization = show_cam_on_image(img_to_show, grayscale_cam, use_rgb=True)\n",
    "\n",
    "    plt.figure(figsize=(10, 5))\n",
    "    plt.subplot(1, 2, 1); plt.imshow(img_to_show[:,:,1], cmap='bone'); plt.title(\"Originale\")\n",
    "    plt.subplot(1, 2, 2); plt.imshow(visualization); plt.title(\"Grad-CAM\")\n",
    "    plt.show()\n",
    "\n",
    "visualize_results(\"/kaggle/working/cervical_model_math.pth\")"
   ]
  }
